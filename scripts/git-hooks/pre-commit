#
# Git pre-commit hook to signal that a version tag should be created
# When version.hpp is committed with a new version, mark it for tagging after commit

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"
VERSION_FILE="include/wxUI/version.hpp"

# Check if version.hpp is being committed
if git diff --cached --name-only | grep -q "^$VERSION_FILE$"; then
    # Extract version from staged version.hpp
    NEW_VERSION=$(git diff --cached "$VERSION_FILE" | grep "^+#define WXUI_VERSION_STRING" | cut -d'"' -f2)
    
    if [ -n "$NEW_VERSION" ]; then
        TAG_NAME="v$NEW_VERSION"
        
        # Check if tag already exists
        if git rev-parse "$TAG_NAME" >/dev/null 2>&1; then
            echo "⚠️  Tag $TAG_NAME already exists, skipping tag creation"
            rm -f "$PROJECT_ROOT/.git/WXUI_PENDING_TAG"
        else
            # Store version for post-commit hook to create tag
            echo "$NEW_VERSION" > "$PROJECT_ROOT/.git/WXUI_PENDING_TAG"
            echo ""
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "📦 Version update detected: $NEW_VERSION"
            echo "   Tag $TAG_NAME will be created after commit completes"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
        fi
    fi
fi
