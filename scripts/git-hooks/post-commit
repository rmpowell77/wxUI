#!/bin/bash
# Copyright (c) 2025 Richard Powell
#
# Git post-commit hook to automatically create version tags
# This runs after a commit completes and creates the tag if version.hpp was updated

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"
PENDING_TAG_FILE="$PROJECT_ROOT/.git/WXUI_PENDING_TAG"

# Check if there's a pending tag to create
if [ -f "$PENDING_TAG_FILE" ]; then
    NEW_VERSION=$(cat "$PENDING_TAG_FILE")
    TAG_NAME="v$NEW_VERSION"
    
    # Create the tag on the commit we just made
    if git tag -a "$TAG_NAME" -m "wxUI-$TAG_NAME"; then
        echo ""
        echo "================================================"
        echo "Created tag: $TAG_NAME"
        echo "   Remember to push with: git push origin main --tags"
        echo "================================================"
        echo ""
    else
        echo "ERROR: Failed to create tag $TAG_NAME"
    fi
    
    # Clean up the pending tag file
    rm -f "$PENDING_TAG_FILE"
fi
