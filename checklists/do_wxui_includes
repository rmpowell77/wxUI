#!/bin/bash

# Auto-fix wxUI.hpp to include all top-level headers from include/wxUI/
# This script regenerates the #include section with all headers in alphabetical order
# while preserving the license header at the top of the file

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
ROOT_DIR="${SCRIPT_DIR}/.."
WXUI_HPP="${ROOT_DIR}/include/wxUI/wxUI.hpp"

# Get all headers except wxUI.hpp itself, in alphabetical order
ALL_HEADERS=$(find "${ROOT_DIR}/include/wxUI" -maxdepth 1 -name "*.hpp" -type f ! -name "wxUI.hpp" | xargs -n1 basename | sort)

# Backup the original file
cp "${WXUI_HPP}" "${WXUI_HPP}.bak"

# Extract the license header and #pragma once (everything before the first #include)
# This preserves the copyright notice at the top of the file
awk '/^#include/ {exit} {print}' "${WXUI_HPP}.bak" > "${WXUI_HPP}.tmp.header"

# Generate all includes in alphabetical order
# Put version.hpp first, then all others, then wxUITypes.hpp last
{
    echo '#include <wxUI/version.hpp>'
    echo ''
    
    echo "$ALL_HEADERS" | while read header; do
        if [ "$header" != "version.hpp" ] && [ "$header" != "wxUITypes.hpp" ]; then
            echo "#include <wxUI/$header>"
        fi
    done
    
    if echo "$ALL_HEADERS" | grep -q "wxUITypes.hpp"; then
        echo "#include <wxUI/wxUITypes.hpp>"
    fi
} > "${WXUI_HPP}.tmp.includes"

# Combine license header and includes to create the complete file
cat "${WXUI_HPP}.tmp.header" "${WXUI_HPP}.tmp.includes" > "${WXUI_HPP}"

# Clean up temporary files
rm -f "${WXUI_HPP}.tmp.header" "${WXUI_HPP}.tmp.includes" "${WXUI_HPP}.bak"

echo "✓ Updated wxUI.hpp with all headers (license preserved)"
"${SCRIPT_DIR}/check_wxui_includes"
